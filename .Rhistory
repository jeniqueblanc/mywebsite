rm(list = ls())
library(tidyverse)
library(dplyr)
load("naic_asset.rta")
temp <- MyData |> select(COCODE, COMPANY_NAME, COMPANY_TYPE_DESC, CURRENT_YEAR, YEAR, LINE)
longdata <- temp |>
filter(LINE%in%c("Bonds", "CashHandDeposit","Stocks_Com","Total"))
widedata <- longdata |>
pivot_wider(
names_from  = LINE,
values_from = CURRENT_YEAR
) |>
filter(!is.na(Total), Total > 0)
widedata <- widedata |>
mutate(
bondRatio  = Bonds / Total,
stockRatio = Stocks_Com / Total,
YEAR = factor(YEAR),
COMPANY_TYPE_DESC = factor(COMPANY_TYPE_DESC)
)
longdata <- widedata |>
pivot_longer(
cols = -c(COCODE, YEAR, COMPANY_NAME, COMPANY_TYPE_DESC),
names_to  = "name",
values_to = "value"
)
longdata |>
filter(name == "Total") |>
ggplot(aes(x = YEAR, y = value)) +
geom_point(alpha = 0.5) +
theme_bw() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Total Assets Over Time",
x = "Year", y = "Total Assets")
longdata |>
filter(name == "Total") |>
ggplot(aes(x = YEAR, y = value, color = COMPANY_TYPE_DESC)) +
geom_point(alpha = 0.5) +
theme_bw() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
) +
labs(title = "Total Assets Over Time by Company Type",
x = "Year", y = "Total Assets", color = "Company Type")
longdata |>
filter(name == "Total") |>
ggplot(aes(x = YEAR, y = value)) +
geom_boxplot(outlier.alpha = 0.3) +
theme_bw() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Distribution of Total Assets by Year",
x = "Year", y = "Total Assets")
longdata |>
filter(name == "Total") |>
ggplot(aes(x = YEAR, y = value)) +
geom_boxplot(outlier.alpha = 0.3) +
ylim(0, 1e8) +
theme_bw() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(title = "Distribution of Total Assets by Year (Zoomed)",
x = "Year", y = "Total Assets (0 to 1e8)")
longdata |>
filter(name == "bondRatio") |>
ggplot(aes(x = YEAR, y = value, fill = COMPANY_TYPE_DESC)) +
geom_boxplot(outlier.alpha = 0.3) +
ylim(0, 1) +
theme_bw() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
) +
labs(title = "Bond Ratio Distribution by Year and Company Type",
x = "Year", y = "Bond Ratio", fill = "Company Type")
longdata |>
filter(name %in% c("bondRatio", "stockRatio")) |>
ggplot(aes(x = YEAR, y = value)) +
geom_boxplot(outlier.alpha = 0.3) +
ylim(0, 1) +
facet_grid(name ~ COMPANY_TYPE_DESC) +
theme_bw() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
) +
labs(title = "Bond vs Stock Ratio Distributions by Year and Company Type",
x = "Year", y = "Ratio")
avg_ratios <- longdata |>
filter(name %in% c("bondRatio", "stockRatio")) |>
pivot_wider(names_from = name, values_from = value) |>
group_by(YEAR, COMPANY_TYPE_DESC) |>
summarise(
bondRatio  = mean(bondRatio, na.rm = TRUE),
stockRatio = mean(stockRatio, na.rm = TRUE),
.groups = "drop"
) |>
pivot_longer(
cols = c(bondRatio, stockRatio),
names_to = "name",
values_to = "value"
)
avg_ratios |>
ggplot(aes(x = YEAR, y = value, fill = name)) +
geom_col(position = "stack") +
facet_wrap(~ COMPANY_TYPE_DESC) +
ylim(0, 1) +
theme_bw() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "bottom"
) +
labs(
title = "Average Bond and Stock Ratios Over Time (Stacked)",
x = "Year",
y = "Average Ratio",
fill = "Ratio Type"
)
