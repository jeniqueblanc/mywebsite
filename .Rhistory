library(forecast)
EMPTPA <- ts(data$EMPTPA, start=c(2000, 1), frequency=12)
data <- read.csv("~/Downloads/Project1_EMP_Data (1).csv")
View(data)
library(forecast)
EMPTPA <- ts(data$EMPTPA, start=c(2000, 1), frequency=12)
model1 <- function(x, h) {
forecast(auto.arima(x, max.p = 12, max.q=12, seasonal=FALSE, ic="bic"),
h=h)}
model2 <- function(x, h) {
forecast(tslm(x ~ trend + I(trend^2)), h=h)}
############## EXPANDING WINDOW #######################
# Cross validation procedure. Produces forecast errors
model1_e <- tsCV(EMPTPA, model1, h=12, initial = 59)
model2_e <- tsCV(EMPTPA, model2, h=12, initial = 59)
# RMSE Expanding window
sqrt(mean(model1_e[,1]^2, na.rm = TRUE))
sqrt(mean(model2_e[,1]^2, na.rm = TRUE))
sqrt(mean(model1_e[,12]^2, na.rm = TRUE))
sqrt(mean(model2_e[,12]^2, na.rm = TRUE))
# Diebold-Mariano Test for 1-step ahead forecasts
dm_1step_e <- dm.test(model1_e[, 1], model2_e[, 1], alternative =
"two.sided", h = 1)
print(dm_1step_e)
# Diebold-Mariano Test for 12-step ahead forecasts
dm_12step_e <- dm.test(model1_e[, 12], model2_e[, 12], alternative =
"two.sided", h = 12)
print(dm_12step_e)
############## ROLLING WINDOW #######################
# Cross validation procedure. Produces forecast errors
model1_r <- tsCV(EMPTPA, model1, h=12, window = 60)
model2_r <- tsCV(EMPTPA, model2, h=12, window = 60)
# RMSE Rolling window
sqrt(mean(model1_r[,1]^2, na.rm = TRUE))
sqrt(mean(model2_r[,1]^2, na.rm = TRUE))
sqrt(mean(model1_r[,12]^2, na.rm = TRUE))
sqrt(mean(model2_r[,12]^2, na.rm = TRUE))
# Diebold-Mariano Test for 1-step ahead forecasts
dm_1step_r <- dm.test(model1_r[, 1], model2_r[, 1], alternative =
"two.sided", h = 1)
print(dm_1step_r)
# Diebold-Mariano Test for 12-step ahead forecasts
dm_12step_r <- dm.test(model1_r[, 12], model2_r[, 12], alternative =
"two.sided", h = 12)
print(dm_12step_r)
