Project1_EMP_Data <- read.csv("~/Downloads/Project1_EMP_Data.csv")
View(Project1_EMP_Data)
library(forecast)
TPA <- ts(Project1_EMP_Data$EMPTPA, start = c(2000,1), frequency = 12)
plot(TPA, main = "Employment of Tampa")
#Linear Model
Regression1 <- tslm(TPA ~ trend + season)
summary(Regression1)
plot(TPA, main = "Employment of Tampa", ylab = "Number of people", xlab
= "Years")
lines(fitted(Regression1), col = "blue", lty = 2)
AIC(Regression1)
BIC(Regression1)
forecast_model <- forecast(Regression1, h = 12)
print(forecast_model)
plot(forecast_model, main = "Tampa Forecasted Employment Data")
lines(fitted(Regression1), col = "blue", lty = 2)
#Quadratic Model
Regression2 <- tslm(TPA ~ trend + I(trend^2) + season)
summary(Regression2)
plot(TPA, main = "Employment of Tampa", ylab = "Number of people", xlab = "Year")
lines(fitted(Regression2), col = "blue", lty = 2)
AIC(Regression2)
BIC(Regression2)
forecast_model_2 <- forecast(Regression2, h = 12)
print(forecast_model_2)
plot(forecast_model_2, main = "Tampa Foreasted Employment Data")
lines(fitted(Regression2), col = "blue", lty = 2)
#Log Linear Model
Regression3 <- tslm(log(TPA) ~ trend + season)
summary(Regression3)
plot(log(TPA), main = "Employment of Tampa", ylab = "Number of People", xlab = "Year")
lines(fitted(Regression3), col = "blue", lty = 2)
AIC(Regression3)
BIC(Regression3)
forecast_model_3 <- forecast(Regression3, h = 12)
print(forecast_model_3)
plot(forecast_model_3, main = "Tampa Forecasted Employment Data in Log")
lines(fitted(Regression3), col = "blue", lty = 2)
#Log Linear Adjusted Model
regression4 <- tslm(TPA ~ trend, lambda = 0, biasadj = TRUE, level = 95)
summary(regression4)
AIC(regression4)
BIC(regression4)
forecast_model_4 <- forecast(regression4, biasadj = TRUE, h = 12, level = 95)
print(forecast_model_4)
plot(forecast_model_4)
lines(fitted(regression4), col = "blue", lty = 2)
#Making the AIC and BIC interpretable
RAWLogLinearAIC <- AIC(regression4)
RAWLogLinearBIC <- BIC(regression4)
sum_log_y <- sum(log(as.numeric(TPA)), na.rm = TRUE)
LogLinearAIC <- RAWLogLinearAIC + 2 * sum_log_y
LogLinearBIC <- RAWLogLinearBIC + 2 * sum_log_y
print(LogLinearAIC)
print(LogLinearBIC)
# Set up
library(forecast)
RPCENSA <- ts(Consumption.Quarterly$RPCENSA, start = c(2002, 1), frequency = 4)
# Comparing levels and logs
plot(RPCENSA, main="RPCENSA (in levels)")
plot(log(RPCENSA), main="Log(RPCENSA)")
# Forecast horizon
forecast_horizon <- 8
# Manually specifying log(RPCENSA) as the dependent variable
manual_loglinear_trend <- tslm(log(RPCENSA) ~ trend)
summary(manual_loglinear_trend)
AIC(manual_loglinear_trend)
BIC(manual_loglinear_trend)
manual_loglinear_for <- forecast(manual_loglinear_trend, h= forecast_horizon, level
= 95)
print(manual_loglinear_for)
plot(manual_loglinear_for)
# “Smart way” (Box-Cox with lambda=0 sets up a log transform internally)
loglinear_trend <- tslm(RPCENSA~ trend, lambda=0, biasadj = TRUE, level = 95)
summary(loglinear_trend)
AIC(loglinear_trend)
BIC(loglinear_trend)
loglinear_for <- forecast(loglinear_trend, biasadj = TRUE, h = forecast_horizon,
level =95)
print(loglinear_for)
plot(loglinear_for)
# AIC and BIC comparable to models in levels
AIC_raw_loglinear <- AIC(loglinear_trend)
BIC_raw_loglinear <- BIC(loglinear_trend)
sum_log_y <- sum(log(as.numeric(RPCENSA)), na.rm = TRUE)
AIC_adj_loglinear <- AIC_raw_loglinear + 2 * sum_log_y
BIC_adj_loglinear <- BIC_raw_loglinear + 2 * sum_log_y
print(AIC_adj_loglinear)
print(BIC_adj_loglinear)
